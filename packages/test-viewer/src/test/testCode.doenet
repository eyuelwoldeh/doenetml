<section>
  <title>Integer Representation Tests</title>

  <subsection>
    <title>1. Binary: 1001 should equal 9</title>
    <integer name="bin1" representation="binary">1001</integer>
    <p>Display: $bin1</p>
    <p>Value: $bin1.value</p>
    <p>Decimal: $bin1.decimal</p>
  </subsection>

  <subsection>
    <title>2. Hex: FF should equal 255</title>
    <integer name="hex1" representation="hexadecimal">FF</integer>
    <p>Display: $hex1</p>
    <p>Value: $hex1.value</p>
    <p>Decimal: $hex1.decimal</p>
  </subsection>

  <subsection>
    <title>3. Decimal: 16 (default)</title>
    <integer name="dec1">16</integer>
    <p>Display: $dec1</p>
    <p>Value: $dec1.value</p>
    <p>Binary: $dec1.binary</p>
  </subsection>

</section>
